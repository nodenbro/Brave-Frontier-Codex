      "dungeonDescription": "CoF Desc Test",
      "dialogueLines": [
        {
          "id": "01",
          "speakerName": "Tilith",
          "dialogueText": "<style=p>It's so hot! I wanna go home! This is unbearable...</style>",
          "expressionPath": "characters/Tilith/sad",
          "charPrefabPath": "TilithPos"
        },
        {
          "id": "01",
          "speakerName": "Tilith",
          "dialogueText": "<style=h1>Oh! {{user}}!</style>",
          "expressionPath": "characters/Tilith/serious2",
          "charPrefabPath": "TilithPos"
        },
        {
          "id": "01",
          "speakerName": "Tilith",
          "dialogueText": "Hey, you're late! What've you been up to?!",
          "expressionPath": "characters/Tilith/serious",
          "charPrefabPath": "TilithPos"
        }   
        ,
        {
          "id": "01",
          "speakerName": "Tilith",
          "dialogueText": "How could you keep me waiting in this steaming hot cave!",
          "expressionPath": "characters/Tilith/sad",
          "charPrefabPath": "TilithPos"
        },
        {
          "id": "01",
          "speakerName": "Tilith",
          "dialogueText": "I'm beginning to worry about our journey...",
          "expressionPath": "characters/Tilith/worried",
          "charPrefabPath": "TilithPos"
        },
        {
          "id": "01",
          "speakerName": "Tilith",
          "dialogueText": "Well, I did promise I'd tell you more about exactly what's going on...",
          "expressionPath": "characters/Tilith/neutral",
          "charPrefabPath": "TilithPos"
        },
        {
          "id": "01",
          "speakerName": "Tilith",
          "dialogueText": "This is serious, so listen close, OK?",
          "expressionPath": "characters/Tilith/neutral",
          "charPrefabPath": "TilithPos"
        },
        {
          "id": "01",
          "speakerName": "Tilith",
          "dialogueText": "Grand Gaia is in the midst of a great crisis...",
          "expressionPath": "characters/Tilith/serious2",
          "charPrefabPath": "TilithPos"
        }
      ]
    },
